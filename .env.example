# =============================================================================
# MISSION CONTROL — environment variables
# -----------------------------------------------------------------------------
# 1. Copy this file to ".env"  ->  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# 2. Fill in the real values from your Supabase project (see setup guide).
# 3. NEVER commit .env — keep it in .gitignore. This .env.example is the safe,
#    committable template with placeholders only.
# =============================================================================

# Your project's API URL.  Supabase Dashboard -> Project Settings -> Data API
# Looks like: https://abcdefghijklmno.supabase.co
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# ANON / PUBLISHABLE key — safe for the browser/client. Obeys Row Level Security.
# Supabase Dashboard -> Project Settings -> API Keys
SUPABASE_ANON_KEY=your-anon-public-key-here

# SECRET / SERVICE_ROLE key — SERVER-SIDE ONLY. Bypasses Row Level Security and
# can read/write everything. NEVER expose this in client code or the browser.
SUPABASE_SECRET_KEY=your-service-role-secret-key-here
